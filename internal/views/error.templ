package views

templ ErrorPage(message, detail string) {
	@Layout("Error") {
		<div class="rounded-lg border border-red-900/50 bg-red-950/40 p-6">
			<h1 class="text-lg font-semibold text-red-300">{ message }</h1>
			<pre class="mt-3 whitespace-pre-wrap break-words text-xs text-red-200/80">{ detail }</pre>
			<a href="/" class="mt-4 inline-block text-xs text-red-200/80 hover:text-red-100">← back</a>
		</div>
	}
}
